{
  "manifest_version": 3,
  "name": "Sensitive File Scanner",
  "version": "1.2",
  "description": "Проверяет сайт на наличие критичных файлов с прогрессом и поддержкой текущего пути",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Сканировать сайт"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "sensitive-scanner@example.com"
    }
  },
  "icons": {
    "16": "icons/favicon-16x16.png",
    "32": "icons/favicon-32x32.png"
  }
}
